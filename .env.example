# —— LLM（新栈 5-Agent 真实调用所需）——
# OpenAI 官方或任意兼容 /v1/chat/completions 的代理
OPENAI_API_KEY=sk-your-key-here
# 用国内代理 / 第三方网关时填其 base_url；用官方留空
OPENAI_BASE_URL=
# 默认 gpt-4o-mini；可换 gpt-4o 等
OPENAI_MODEL=gpt-4o-mini

# —— 启用新栈（事件驱动 5-Agent 协作环）——
# true/1/yes/on 走新栈；未设/其他值回退老栈（老栈用 FakeLLM，仅演示）
FEATURE_USE_NEW_AGENT_GRAPH=true

# —— 数据库（默认 sqlite，开箱即用，无需改）——
DATABASE_URL=sqlite+aiosqlite:///./study_agent.db
# PostgreSQL (生产环境取消注释):
# DATABASE_URL=postgresql+asyncpg://studyagent:studyagent@localhost:5432/studyagent

# —— 可观测（可选）——
LANGFUSE_ENABLED=false
